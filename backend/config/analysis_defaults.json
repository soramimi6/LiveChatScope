{
  "version": 1,
  "global": {
    "density_bucket_sec": 60,
    "min_token_length": 4,
    "keyword_top_n_overall": 30,
    "keyword_top_n_timeline": 10,
    "topic_label_top_k": 3,
    "clip_padding_sec": 30,
    "delete_tokens_after_stage4": true
  },
  "stage0": {
    "skip_missing_time": true,
    "skip_negative_time": true,
    "super_chat_types": [
      "super_chat",
      "super_sticker",
      "super_chat_event",
      "super_sticker_event"
    ]
  },
  "stage1": {
    "author_top_n": 20,
    "topic_author_top_n": 10
  },
  "stage2": {
    "highlight_top_n": 10,
    "highlight_moving_avg_buckets": 5,
    "highlight_merge_window_sec": 120,
    "highlight_min_score": 1.5,
    "highlight_moving_avg_floor": 1.0
  },
  "stage3": {
    "primary_currency_display": "JPY"
  },
  "stage3b": {
    "membership_burst_min_peak_count": 2,
    "membership_burst_min_ratio": 2.0,
    "membership_burst_baseline_buckets": 3,
    "membership_burst_min_baseline": 1.0,
    "membership_burst_top_n": 5,
    "proximity_window_sec": 120
  },
  "stage4": {
    "tokenizer": "janome",
    "include_pos": ["名詞", "動詞", "形容詞", "副詞"],
    "exclude_pos": ["助詞", "助動詞", "記号", "接続詞", "感動詞"],
    "keyword_min_doc_count": 5,
    "stopwords_file": "stopwords_ja_chat.txt",
    "global_token_detection": {
      "coverage_threshold": 0.8,
      "min_total_count": 20,
      "require_top_n": true
    }
  },
  "stage4b": {
    "burst_min_peak_count": 5,
    "burst_min_ratio": 3.0,
    "burst_baseline_buckets": 3,
    "burst_min_baseline": 1.0,
    "burst_top_n": 20
  },
  "stage5": {
    "topic_distance_metric": "cosine",
    "topic_change_threshold": 0.35,
    "topic_min_block_sec": 180,
    "topic_max_blocks": 20,
    "topic_label_separator": " / "
  },
  "stage6b": {
    "core_regular_min_block_ratio": 0.5
  },
  "stage6c": {
    "low_activity_ratio": 0.5,
    "low_activity_min_sec": 300,
    "low_activity_merge_gap_sec": 60
  },
  "stage7": {
    "summary_highlights_n": 5,
    "summary_keywords_n": 10,
    "summary_topic_preview_n": 6
  },
  "message_filter": {
    "default_exclude_stamp_only": true,
    "allowed_message_types": ["text_message"],
    "default_ng_keywords": [],
    "stamp_only_regexes": [
      "^[\\s]+$",
      "^(:[\\w-]+:\\s*)+$",
      "^[\\U0001F300-\\U0001FAFF\\U00002600-\\U000027BF\\s]+$"
    ]
  }
}
